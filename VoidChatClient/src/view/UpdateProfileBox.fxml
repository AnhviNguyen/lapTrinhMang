<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="updateProfileBox" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <AnchorPane prefHeight="400.0" prefWidth="600.0">
            <children>
                <Label layoutX="200.0" layoutY="30.0" text="Update Profile">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <Label layoutX="50.0" layoutY="100.0" text="Email:" />
                <TextField fx:id="txtEmail" layoutX="150.0" layoutY="95.0" prefWidth="300.0" />
                
                <Label layoutX="50.0" layoutY="140.0" text="First Name:" />
                <TextField fx:id="txtFname" layoutX="150.0" layoutY="135.0" prefWidth="300.0" />
                
                <Label layoutX="50.0" layoutY="180.0" text="Last Name:" />
                <TextField fx:id="txtLname" layoutX="150.0" layoutY="175.0" prefWidth="300.0" />
                
                <Label layoutX="50.0" layoutY="220.0" text="Gender:" />
                <ComboBox fx:id="comboGender" layoutX="150.0" layoutY="215.0" prefWidth="300.0" />
                
                <Label layoutX="50.0" layoutY="260.0" text="Country:" />
                <TextField fx:id="txtCountry" layoutX="150.0" layoutY="255.0" prefWidth="300.0" />
                
                <Button fx:id="btnUpdate" layoutX="250.0" layoutY="320.0" mnemonicParsing="false" onAction="#handleUpdateAction" text="Update Profile" />
            </children>
        </AnchorPane>
    </children>
</VBox> 